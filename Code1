function renderSimulator() {
  const pool = SPECIALTY_POOLS[simSpec];
  const yM = Math.pow(1+pool.gDom/100, simYear);
  const yMI = Math.pow(1+pool.gIntl/100, simYear);
  const totalD = Math.round(pool.dom*yM);
  const totalI = Math.round(pool.intl*yMI);
  const sh = simShares[simSpec];
  const tDA = SIM_IDS.reduce((s,id)=>s+sh[id].d, 0);
  const tIA = SIM_IDS.reduce((s,id)=>s+sh[id].i, 0);

  const td = SIM_IDS.map(id => {
    const h = H(id);
    const dP = Math.round(totalD*sh[id].d/100), iP = Math.round(totalI*sh[id].i/100);
    const dR = Math.round(dP*pool.rDom/1e6*10)/10, iR = Math.round(iP*pool.rIntl/1e6*10)/10;
    return { id, name:h.short, color:h.color, dS:sh[id].d, iS:sh[id].i, dP, iP, tP:dP+iP, dR, iR, tR:Math.round((dR+iR)*10)/10 };
