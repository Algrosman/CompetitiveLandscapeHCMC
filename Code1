    <td style="color:var(--accent-cyan);font-weight:600">${fmt(d.iP)}</td>
    <td style="font-weight:700">${fmt(d.tP)}</td>
    <td style="color:var(--accent-amber)">$${d.dR}M</td>
    <td style="color:var(--accent-purple)">$${d.iR}M</td>
    <td style="font-weight:800">$${d.tR}M</td>
  </tr>`).join('');

  const totRow = `<tr style="border-top:2px solid rgba(255,255,255,0.1)">
    <td style="font-weight:700;color:var(--text-secondary)">TOTAL</td>
    <td style="color:${tDA>100?'var(--accent-red)':'#fff'};font-weight:600">${tDA}%</td>
