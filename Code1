        <div style="display:flex;justify-content:space-between;font-size:9px;color:var(--text-muted)"><span>0%</span><span>60%</span></div>
      </div>`).join('')}
    </div>`;
  }).join('');

  const trs = td.map(d=>`<tr>
    <td style="font-weight:700;color:${d.color};font-family:var(--font-mono)">${d.name}</td>
    <td>${d.dS}%</td><td>${d.iS}%</td>
