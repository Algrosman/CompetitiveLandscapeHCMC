function calcSimData() {
  const pool = SPECIALTY_POOLS[simSpec];
  const yM = Math.pow(1+pool.gDom/100, simYear), yMI = Math.pow(1+pool.gIntl/100, simYear);
  const totalD = Math.round(pool.dom*yM), totalI = Math.round(pool.intl*yMI);
  const sh = simShares[simSpec];
  return SIM_IDS.map(id => {
    const h = H(id);
    const dP = Math.round(totalD*sh[id].d/100), iP = Math.round(totalI*sh[id].i/100);
    const dR = Math.round(dP*pool.rDom/1e6*10)/10, iR = Math.round(iP*pool.rIntl/1e6*10)/10;
    return { id, name:h.short, color:h.color, dS:sh[id].d, iS:sh[id].i, dP, iP, tP:dP+iP, dR, iR, tR:Math.round((dR+iR)*10)/10 };
  });
}

window.setSimSpec = function(sp) { simSpec = sp; renderContent(); };
window.setSimYear = function(v) { simYear = Number(v); renderContent(); };
window.resetSim = function() { simShares = JSON.parse(JSON.stringify(DEFAULT_SHARES)); renderContent(); };
window.updateSim = function(id, type, val) {
  simShares[simSpec][id][type] = Math.max(0, Math.min(60, Number(val)));
  // Fast re-render without full DOM rebuild
  renderContent();
};

