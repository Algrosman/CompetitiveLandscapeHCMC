  const specBtns = Object.keys(SPECIALTY_POOLS).map(sp=>`<button class="spec-btn ${simSpec===sp?'active':''}" onclick="setSimSpec('${sp}')">${sp==='hvti'?'HVTI':sp[0].toUpperCase()+sp.slice(1)}</button>`).join('');

  const sliderCards = SIM_IDS.map(id => {
    const h = H(id);
    return `<div class="sim-hosp-card" style="background:${h.color}08;border:1px solid ${h.color}22">
      <div style="font-family:var(--font-mono);font-size:13px;font-weight:700;color:${h.color};margin-bottom:12px">${h.short}</div>
      ${['d','i'].map(type => `<div style="margin-bottom:${type==='d'?'12':'0'}px">
        <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:11px;color:var(--text-secondary)">${type==='d'?'Domestic':'International'} Capture</span><span style="font-family:var(--font-mono);font-size:13px;font-weight:800;color:#fff" id="lbl_${id}_${type}">${sh[id][type]}%</span></div>
