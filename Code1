      { label:'International', data:td.map(d=>d.iP), backgroundColor:'#4FC3F788', borderColor:'#4FC3F7', borderWidth:1, borderRadius:4 },
    ]},
    options:{ scales:{ x:{stacked:true}, y:{stacked:true, ticks:{callback:v=>fmtK(v)}} } }
  });
  makeChart('chartSimRev', {
    type:'bar',
    data:{ labels:td.map(d=>d.name), datasets:[
      { label:'Dom Rev ($M)', data:td.map(d=>d.dR), backgroundColor:'#FFB74D88', borderColor:'#FFB74D', borderWidth:1 },
