function destroyCharts() { Object.values(charts).forEach(c => c.destroy()); charts = {}; }

function makeChart(canvasId, config) {
  const ctx = document.getElementById(canvasId);
  if (!ctx) return;
  if (charts[canvasId]) charts[canvasId].destroy();
  config.options = config.options || {};
  config.options.responsive = true;
  config.options.maintainAspectRatio = false;
  config.options.plugins = config.options.plugins || {};
  config.options.plugins.legend = config.options.plugins.legend || {};
  config.options.plugins.legend.labels = { color: 'rgba(180,200,220,0.5)', font: { family: "'IBM Plex Mono'", size: 10 }, boxWidth: 12, padding: 12 };
  config.options.plugins.tooltip = config.options.plugins.tooltip || {};
  config.options.plugins.tooltip.backgroundColor = 'rgba(15,20,30,0.95)';
  config.options.plugins.tooltip.borderColor = 'rgba(255,255,255,0.1)';
  config.options.plugins.tooltip.borderWidth = 1;
  config.options.plugins.tooltip.titleFont = { family: "'DM Sans'", size: 12, weight: 700 };
  config.options.plugins.tooltip.bodyFont = { family: "'IBM Plex Mono'", size: 11 };
  config.options.plugins.tooltip.padding = 10;
  config.options.plugins.tooltip.cornerRadius = 8;
  const defaultScale = { ticks: { color: 'rgba(180,200,220,0.4)', font: { family: "'IBM Plex Mono'", size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { display: false } };
  if (config.options.scales) {
    Object.keys(config.options.scales).forEach(k => {
      config.options.scales[k] = { ...defaultScale, ...config.options.scales[k], ticks: { ...defaultScale.ticks, ...(config.options.scales[k].ticks||{}) }, grid: { ...defaultScale.grid, ...(config.options.scales[k].grid||{}) } };
    });
  }
  charts[canvasId] = new Chart(ctx, config);
  return charts[canvasId];
}

function stars(r) {
  const f = Math.floor(r), half = r%1>=0.3;
  return `<span class="star-rating">${'★'.repeat(f)}${half?'½':''}<span class="dim">${'★'.repeat(5-f-(half?1:0))}</span><span class="val">${r}</span></span>`;
}

function badge(text, color) {
  return `<span class="badge" style="background:${color}22;color:${color};border:1px solid ${color}44">${text}</span>`;
}

